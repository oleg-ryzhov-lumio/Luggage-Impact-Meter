<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SafeGrid</title>
    <style>
        :root {
            --bg-sidebar: #f8fafc;
            --bg-main: #ffffff;
            --bg-hover: #f1f5f9;
            --bg-selected: #e2e8f0;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --primary-light: #eff6ff;
            --danger: #ef4444;
            --danger-hover: #dc2626;
            --danger-light: #fef2f2;
            --warning: #f59e0b;
            --radius: 8px;
            --font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, Roboto, Helvetica, Arial, sans-serif;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: var(--font-family); }
        body { height: 100vh; display: flex; overflow: hidden; background-color: var(--bg-main); color: var(--text-main); font-size: 14px; }
        
        /* Layout */
        .sidebar { width: 260px; background-color: var(--bg-sidebar); border-right: 1px solid var(--border); display: flex; flex-direction: column; }
        .main-view { flex-grow: 1; display: flex; flex-direction: column; background-color: var(--bg-main); }
        
        /* Icons */
        svg { width: 18px; height: 18px; stroke: currentColor; stroke-width: 2; fill: none; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
        
        /* Sidebar Elements */
        .sidebar-header { padding: 20px 16px; border-bottom: 1px solid var(--border); font-weight: 600; font-size: 15px; display: flex; align-items: center; gap: 10px; color: var(--text-main); }
        .sidebar-content { flex-grow: 1; overflow-y: auto; padding: 12px 8px; }
        .sidebar-item { padding: 10px 12px; display: flex; align-items: center; gap: 10px; cursor: pointer; color: var(--text-main); user-select: none; border-radius: var(--radius); margin-bottom: 2px; transition: background 0.15s, color 0.15s; font-weight: 500; }
        .sidebar-item:hover { background-color: var(--bg-hover); }
        .sidebar-item.active { background-color: var(--bg-selected); color: var(--text-main); }
        .sidebar-divider { height: 1px; background: var(--border); margin: 12px 4px; }
        
        /* Sidebar Footer Container */
        .sidebar-footer { padding: 16px; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 16px; background: #fafafa; }
        .storage-wrapper { padding: 0 4px; font-size: 12px; color: var(--text-muted); }
        .storage-text { margin-top: 6px; display: block; font-size: 11px; }
        .progress-bar-bg { width: 100%; height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden; margin-top: 6px; }
        .progress-bar-fill { width: 0%; height: 100%; background: var(--primary); transition: width 0.3s ease; }
        
        /* Ribbon & Search Controls */
        .ribbon { padding: 12px 20px; border-bottom: 1px solid var(--border); display: flex; gap: 10px; background-color: #ffffff; align-items: center; min-height: 57px; flex-wrap: wrap; }
        .search-container { position: relative; display: flex; align-items: center; margin-left: 4px; }
        .search-container input { padding: 8px 12px 8px 34px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; outline: none; width: 180px; transition: all 0.2s; background: var(--bg-sidebar); }
        .search-container input:focus { border-color: var(--primary); background: var(--bg-main); width: 220px; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
        .search-container svg { position: absolute; left: 10px; color: var(--text-muted); pointer-events: none; }
        
        .breadcrumb { padding: 10px 20px; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 6px; background: var(--bg-sidebar); font-weight: 500; }
        .breadcrumb span.crumb-link { color: var(--primary); cursor: pointer; }
        .breadcrumb span.crumb-link:hover { text-decoration: underline; }
        
        /* Content Display Modes */
        .content-area { flex-grow: 1; overflow-y: auto; position: relative; background: var(--bg-main); }
        .drag-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(37, 99, 235, 0.08); border: 2px dashed var(--primary); display: none; justify-content: center; align-items: center; color: var(--primary); font-size: 16px; font-weight: 600; z-index: 10; pointer-events: none; border-radius: var(--radius); margin: 8px; }
        .content-area.drag-over .drag-overlay { display: flex; }

        /* Modern UI Buttons */
        .btn { padding: 8px 14px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg-main); color: var(--text-main); cursor: pointer; display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 500; transition: all 0.15s; user-select: none; box-shadow: var(--shadow-sm); }
        .btn:hover:not(:disabled) { background-color: var(--bg-hover); border-color: #cbd5e1; }
        .btn:active:not(:disabled) { transform: scale(0.98); }
        .btn:disabled { color: var(--text-muted); cursor: not-allowed; opacity: 0.5; box-shadow: none; }
        .btn-primary { background-color: var(--primary); color: white; border-color: var(--primary); }
        .btn-primary:hover:not(:disabled) { background-color: var(--primary-hover); border-color: var(--primary-hover); }
        .btn-danger { color: var(--danger); }
        .btn-danger:hover:not(:disabled) { background-color: var(--danger-light); border-color: var(--danger); }
        
        /* Modern Icon Buttons */
        .btn-icon { padding: 8px; border-radius: var(--radius); border: 1px solid transparent; background: transparent; cursor: pointer; color: var(--text-muted); display: inline-flex; align-items: center; justify-content: center; transition: all 0.15s; }
        .btn-icon:hover { background-color: var(--bg-hover); color: var(--text-main); border-color: var(--border); }
        .btn-icon.active { background-color: var(--bg-selected); color: var(--primary); border-color: var(--border); }
        .btn-icon.star-filled { color: var(--warning); }
        .btn-icon.star-filled:hover { color: #d97706; }

        /* Tables View */
        table { width: 100%; border-collapse: collapse; text-align: left; }
        th { padding: 12px 20px; border-bottom: 1px solid var(--border); font-weight: 600; color: var(--text-muted); position: sticky; top: 0; background: var(--bg-main); font-size: 13px; user-select: none; cursor: pointer; transition: background 0.15s; }
        th:hover { background-color: var(--bg-sidebar); }
        td { padding: 12px 20px; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--text-main); }
        
        /* Drag and Drop Item row highlighting targets */
        tr.draggable-row { cursor: grab; }
        tr.draggable-row:active { cursor: grabbing; }
        tr.drag-target-hover td { background-color: var(--primary-light) !important; border-top: 1px solid var(--primary); border-bottom: 1px solid var(--primary); }
        tr:hover td { background-color: #f8fafc; }

        /* Full Clickable Cell Styling */
        td.clickable-cell { cursor: pointer; font-weight: 500; }
        td.clickable-cell:hover { color: var(--primary); }

        .col-name { display: flex; align-items: center; gap: 10px; }
        .col-actions { text-align: right; white-space: nowrap; }

        /* Grid Layout View */
        .grid-view { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 16px; padding: 20px; }
        .grid-card { border: 1px solid var(--border); border-radius: var(--radius); padding: 20px 16px; display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; cursor: pointer; transition: all 0.15s; user-select: none; background: var(--bg-main); box-shadow: var(--shadow-sm); }
        .grid-card:hover { border-color: var(--primary); background: var(--primary-light); transform: translateY(-1px); box-shadow: var(--shadow-md); }
        .grid-card svg.main-icon { width: 44px; height: 44px; margin-bottom: 10px; }
        .grid-card .card-name { font-size: 13px; font-weight: 500; text-overflow: ellipsis; overflow: hidden; width: 100%; white-space: nowrap; color: var(--text-main); }
        .grid-card .card-actions { display: flex; justify-content: center; gap: 4px; margin-top: 12px; width: 100%; opacity: 0; transition: opacity 0.15s; }
        .grid-card:hover .card-actions { opacity: 1; }
        .grid-card .fav-star { position: absolute; top: 8px; right: 8px; color: var(--text-muted); cursor: pointer; transition: color 0.15s; }
        .grid-card .fav-star.star-filled { color: var(--warning); }
        .grid-card.drag-target-hover { border-color: var(--primary); background-color: var(--primary-light); box-shadow: var(--shadow-md); }

        /* General Center Container Alignment */
        .center-msg { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: var(--text-muted); display: flex; flex-direction: column; align-items: center; gap: 14px; width: 90%; max-width: 400px; }
        .lock-screen { width: 100%; background: #ffffff; padding: 24px; border-radius: var(--radius); border: 1px solid var(--border); box-shadow: var(--shadow-md); }
        .lock-screen h3 { margin-bottom: 16px; font-size: 16px; font-weight: 600; }
        .lock-screen input { width: 100%; padding: 10px 14px; margin-bottom: 14px; border: 1px solid var(--border); border-radius: var(--radius); outline: none; font-size: 14px; transition: border 0.15s; }
        .lock-screen input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
        
        /* Editor */
        .editor-wrapper { display: flex; flex-direction: column; height: 100%; }
        .editor-textarea { flex-grow: 1; width: 100%; padding: 20px; border: none; outline: none; font-family: "Consolas", "Courier New", monospace; font-size: 14px; resize: none; line-height: 1.5; }

        /* Modals */
        .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15, 23, 42, 0.3); backdrop-filter: blur(2px); display: none; justify-content: center; align-items: center; z-index: 100; transition: all 0.2s; }
        .modal-overlay.active { display: flex; }
        .modal { background: var(--bg-main); width: 100%; max-width: 400px; padding: 24px; border-radius: var(--radius); box-shadow: var(--shadow-md); border: 1px solid var(--border); animation: modalFade 0.2s ease-out; }
        @keyframes modalFade { from { transform: translateY(8px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .modal-header { font-size: 16px; font-weight: 600; margin-bottom: 16px; color: var(--text-main); }
        .modal-body label { display: block; font-size: 12px; font-weight: 500; color: var(--text-muted); margin-bottom: 6px; margin-top: 10px; }
        .modal-body input { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 14px; outline: none; transition: border 0.15s; }
        .modal-body input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
        .modal-footer { display: flex; justify-content: flex-end; gap: 10px; margin-top: 24px; }

        .hidden { display: none !important; }
        .v-hidden { visibility: hidden !important; }
        .svg-folder { color: #e2a03f; fill: #f8e3c2; }
        .svg-file { color: var(--text-muted); }
        .star-filled svg { fill: var(--warning); color: var(--warning); }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            SafeGrid
        </div>
        <div class="sidebar-content">
            <div id="vaultList"></div>
            
            <div id="systemFolders" class="hidden">
                <div class="sidebar-divider"></div>
                <div class="sidebar-item active" id="sideItemFiles" onclick="switchSystemView('files')">
                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
                    <span>All Files</span>
                </div>
                <div class="sidebar-item" id="sideItemFavs" onclick="switchSystemView('favorites')">
                    <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    <span>Favorites</span>
                </div>
                <div class="sidebar-item" id="sideItemTrash" onclick="switchSystemView('trash')">
                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                    <span>Recycle Bin</span>
                </div>
            </div>
        </div>
        
        <div class="sidebar-footer">
            <div class="storage-wrapper">
                <div style="display: flex; align-items: center; gap: 6px;">
                    <svg viewBox="0 0 24 24" style="width:14px; height:14px;"><path d="M22 12H2M22 6H2M22 18H2"></path></svg>
                    <span>Storage Usage</span>
                </div>
                <div class="progress-bar-bg">
                    <div id="storageBar" class="progress-bar-fill"></div>
                </div>
                <span id="storageText" class="storage-text">Calculating...</span>
            </div>
            <button class="btn btn-primary" style="width: 100%; justify-content: center;" onclick="openModal('createVaultModal')">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                New Vault
            </button>
        </div>
    </div>

    <div class="main-view">
        <div class="ribbon v-hidden" id="actionRibbon">
            <button class="btn" id="btnNewFolder" onclick="openModal('createFolderModal')">
                <svg class="svg-folder" viewBox="0 0 24 24"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                New Folder
            </button>
            <label class="btn" id="btnUpload">
                <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                Upload File
                <input type="file" id="fileUploadInput" class="hidden" multiple>
            </label>
            <button class="btn" id="btnNewText" onclick="openModal('createTextFileModal')">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                Text File
            </button>
            
            <div style="width: 1px; height: 24px; background: var(--border); margin: 0 4px;"></div>
            
            <button class="btn-icon active" title="List View" id="btnViewList" onclick="setViewMode('list')">
                <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
            </button>
            <button class="btn-icon" title="Grid View" id="btnViewGrid" onclick="setViewMode('grid')">
                <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            </button>

            <div class="search-container">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" id="searchInput" placeholder="Search vault..." oninput="filterItems()">
            </div>

            <div style="flex-grow: 1;"></div>
            
            <button class="btn" onclick="openVaultSettingsModal()"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg> Settings</button>
            <button class="btn" onclick="lockVault()"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> Lock Vault</button>
            <button class="btn btn-danger" onclick="deleteVault()"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg> Delete Vault</button>
        </div>

        <div class="breadcrumb" id="breadcrumb">This PC > Select a Vault</div>

        <div class="content-area" id="mainContent">
            <div class="drag-overlay">Drop files here to upload instantly</div>

            <div id="viewEmpty" class="center-msg">
                <svg style="width: 48px; height: 48px; color: var(--text-muted); opacity: 0.4;" viewBox="0 0 24 24"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                <p>Select an existing vault from the sidebar or make a new one.</p>
            </div>

            <div id="viewUnlock" class="center-msg hidden">
                <div class="lock-screen">
                    <h3 id="unlockTitle">Unlock Vault</h3>
                    <input type="password" id="vaultPasswordInput" placeholder="Master Password" onkeypress="if(event.key === 'Enter') unlockVault()">
                    <button class="btn btn-primary" style="width: 100%; justify-content: center;" onclick="unlockVault()">Unlock</button>
                </div>
            </div>

            <div id="viewFiles" class="hidden" style="height: 100%; overflow-y:auto;">
                <table id="fileTable">
                    <thead>
                        <tr>
                            <th onclick="toggleSort('name')">Name <span id="sortDirection"></span></th>
                            <th onclick="toggleSort('type')">Type</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="fileListBody"></tbody>
                </table>
                <div id="gridViewContainer" class="grid-view hidden"></div>
                <div id="emptyFilesMsg" class="center-msg hidden"><p>This directory is empty.</p></div>
            </div>

            <div id="viewEditor" class="editor-wrapper hidden">
                <div style="padding: 12px 20px; border-bottom: 1px solid var(--border); background: #fafafa; display: flex; justify-content: space-between; align-items: center;">
                    <span id="editorFilename" style="font-weight: 600;">document.txt</span>
                    <div style="display: flex; gap: 8px;">
                        <button class="btn" onclick="closeEditor()">Cancel</button>
                        <button class="btn btn-primary" onclick="saveEditorFile()">Save Changes</button>
                    </div>
                </div>
                <textarea id="editorTextarea" class="editor-textarea" spellcheck="false"></textarea>
            </div>
        </div>
    </div>

    <div id="createVaultModal" class="modal-overlay">
        <div class="modal">
            <div class="modal-header">Create Vault</div>
            <div class="modal-body">
                <label>Vault Name</label>
                <input type="text" id="newVaultName" placeholder="Vault Name" onkeypress="if(event.key === 'Enter') createVault()">
                <label>Master Password</label>
                <input type="password" id="newVaultPassword" placeholder="Password" onkeypress="if(event.key === 'Enter') createVault()">
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('createVaultModal')">Cancel</button>
                <button class="btn btn-primary" onclick="createVault()">Create</button>
            </div>
        </div>
    </div>

    <div id="createFolderModal" class="modal-overlay">
        <div class="modal">
            <div class="modal-header">New Folder</div>
            <div class="modal-body">
                <label>Folder Name</label>
                <input type="text" id="newFolderName" placeholder="Folder Name" onkeypress="if(event.key === 'Enter') createFolder()">
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('createFolderModal')">Cancel</button>
                <button class="btn btn-primary" onclick="createFolder()">Create</button>
            </div>
        </div>
    </div>

    <div id="createTextFileModal" class="modal-overlay">
        <div class="modal">
            <div class="modal-header">New Text Document</div>
            <div class="modal-body">
                <label>File Name</label>
                <input type="text" id="newFileName" placeholder="notes.txt" onkeypress="if(event.key === 'Enter') initiateNewTextFile()">
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('createTextFileModal')">Cancel</button>
                <button class="btn btn-primary" onclick="initiateNewTextFile()">Open Editor</button>
            </div>
        </div>
    </div>

    <div id="renameItemModal" class="modal-overlay">
        <div class="modal">
            <div class="modal-header">Rename Item</div>
            <div class="modal-body">
                <label>New Name</label>
                <input type="text" id="renameItemInput" placeholder="Enter new name..." onkeypress="if(event.key === 'Enter') saveItemRename()">
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('renameItemModal')">Cancel</button>
                <button class="btn btn-primary" onclick="saveItemRename()">Rename</button>
            </div>
        </div>
    </div>

    <div id="vaultSettingsModal" class="modal-overlay">
        <div class="modal">
            <div class="modal-header">Vault Settings</div>
            <div class="modal-body">
                <label>Rename Vault</label>
                <input type="text" id="settingsVaultName" placeholder="Vault Name">
                <div style="height:1px; background:var(--border); margin:16px 0;"></div>
                <label>Change Master Password</label>
                <input type="password" id="settingsVaultPassword" placeholder="New Password">
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('vaultSettingsModal')">Cancel</button>
                <button class="btn btn-primary" onclick="saveVaultSettings()">Save Settings</button>
            </div>
        </div>
    </div>

<script>
let db, selectedVaultId = null, currentVault = null, activeCryptoKey = null, editingFileId = null;
let currentDirectoryPath = "/", currentSystemView = "files", viewMode = "list", sortField = "name", sortAsc = true;
let runtimeCachedItems = []; 
let draggedItemId = null, renamingItemId = null;

const ICON_FOLDER = `<svg class="svg-folder" viewBox="0 0 24 24"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>`;
const ICON_FILE_TEXT = `<svg class="svg-file" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>`;
const ICON_FILE_GENERIC = `<svg class="svg-file" viewBox="0 0 24 24"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>`;

// --- Core Database Engine ---
const request = indexedDB.open("ExplorerVaultProDB", 2);
request.onupgradeneeded = (e) => {
    db = e.target.result;
    if(!db.objectStoreNames.contains("vaults")) db.createObjectStore("vaults", { keyPath: "id", autoIncrement: true });
    if(!db.objectStoreNames.contains("files")) {
        const fileStore = db.createObjectStore("files", { keyPath: "id", autoIncrement: true });
        fileStore.createIndex("vaultId", "vaultId", { unique: false });
    }
};
request.onsuccess = (e) => { db = e.target.result; loadVaults(); updateStorageSpace(); };

// --- UI Framework Systems ---
function openModal(id) { document.getElementById(id).classList.add('active'); setTimeout(() => { const inp = document.querySelector(`#${id} input`); if(inp) inp.focus(); }, 100); }
function closeModal(id) { document.getElementById(id).classList.remove('active'); document.querySelectorAll(`#${id} input`).forEach(i=>i.value=''); }

function setViewMode(mode) { 
    viewMode = mode; 
    document.getElementById('btnViewList').classList.toggle('active', mode === 'list');
    document.getElementById('btnViewGrid').classList.toggle('active', mode === 'grid');
    filterItems(); 
}

function switchSystemView(view) {
    currentSystemView = view;
    currentDirectoryPath = "/";
    document.querySelectorAll('.sidebar-item').forEach(el => { if(el.id.startsWith("sideItem")) el.classList.remove('active'); });
    if(view === 'files') document.getElementById('sideItemFiles').classList.add('active');
    if(view === 'favorites') document.getElementById('sideItemFavs').classList.add('active');
    if(view === 'trash') document.getElementById('sideItemTrash').classList.add('active');
    renderBreadcrumbs();
    loadFiles();
}

function renderBreadcrumbs() {
    if (!currentVault) return;
    let html = `<svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg> <span class="crumb-link" onclick="navigateToPath('/')">${currentVault.name}</span>`;
    if(currentSystemView === "favorites") html += ` &gt; <span>Favorites</span>`;
    if(currentSystemView === "trash") html += ` &gt; <span>Recycle Bin</span>`;
    
    if (currentDirectoryPath !== "/" && currentSystemView === "files") {
        let built = "/";
        currentDirectoryPath.split('/').filter(s=>s).forEach(seg => {
            built += seg + "/";
            const snap = built;
            html += ` &gt; <span class="crumb-link" onclick="navigateToPath('${snap.replace(/'/g, "\\'")}')">${seg}</span>`;
        });
    }
    document.getElementById('breadcrumb').innerHTML = html;
}

function navigateToPath(path) {
    currentSystemView = "files";
    document.querySelectorAll('.sidebar-item').forEach(el => { if(el.id.startsWith("sideItem")) el.classList.remove('active'); });
    document.getElementById('sideItemFiles').classList.add('active');
    currentDirectoryPath = path;
    renderBreadcrumbs();
    loadFiles();
}

// --- Drag & Drop Core Implementations ---
const dropZone = document.getElementById('mainContent');
window.addEventListener('dragover', e => e.preventDefault());
dropZone.addEventListener('dragenter', (e) => { 
    if(activeCryptoKey && !draggedItemId) dropZone.classList.add('drag-over'); 
});
dropZone.addEventListener('dragleave', (e) => { 
    if(e.relatedTarget === null || !dropZone.contains(e.relatedTarget)) dropZone.classList.remove('drag-over'); 
});
dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    if(!activeCryptoKey || currentSystemView === 'trash') return;
    if(e.dataTransfer.files.length > 0) {
        handleFileBatch(e.dataTransfer.files);
    }
});

async function handleFileBatch(files) {
    for(let file of files) {
        await new Promise(res => {
            const r = new FileReader();
            r.onload = async (evt) => {
                await saveEncryptedData(file.name, file.type, evt.target.result);
                res();
            };
            r.readAsArrayBuffer(file);
        });
    }
    loadFiles();
}

function handleItemDragStart(e, id) {
    draggedItemId = id;
    e.dataTransfer.effectAllowed = "move";
}

function handleItemDragOver(e, targetElement, targetType) {
    if(!draggedItemId || targetType !== 'folder') return;
    e.preventDefault();
    targetElement.classList.add('drag-target-hover');
}

function handleItemDragLeave(targetElement) {
    targetElement.classList.remove('drag-target-hover');
}

function handleItemDrop(e, targetElement, targetFolderName) {
    e.preventDefault();
    targetElement.classList.remove('drag-target-hover');
    if(!draggedItemId) return;
    
    const itemId = draggedItemId;
    draggedItemId = null;

    if(currentSystemView !== 'files') return;

    const tx = db.transaction(["files"], "readwrite");
    const store = tx.objectStore("files");
    store.get(itemId).onsuccess = (event) => {
        const sourceItem = event.target.result;
        if(!sourceItem) return;

        if(sourceItem.type === 'folder' && sourceItem.name === targetFolderName) return;

        const updatedPath = currentDirectoryPath + targetFolderName + "/";
        sourceItem.path = updatedPath;
        store.put(sourceItem);
    };

    tx.oncomplete = () => loadFiles();
}

// --- Crypto Routine Stubs ---
function generateSalt() { return Array.from(crypto.getRandomValues(new Uint8Array(16))).map(b=>b.toString(16).padStart(2,'0')).join(''); }
async function hashPassword(p, s) { return Array.from(new Uint8Array(await crypto.subtle.digest('SHA-256', new TextEncoder().encode(p + s)))).map(b=>b.toString(16).padStart(2,'0')).join(''); }
async function deriveKey(p, s) { return await crypto.subtle.importKey('raw', await crypto.subtle.digest('SHA-256', new TextEncoder().encode(p + s)), {name:'AES-GCM'}, false, ['encrypt','decrypt']); }

// --- Vault Administration & Settings ---
function loadVaults() {
    const transaction = db.transaction(["vaults"], "readonly");
    const request = transaction.objectStore("vaults").getAll();
    request.onsuccess = () => {
        const list = document.getElementById('vaultList');
        list.innerHTML = '';
        request.result.forEach(v => {
            const item = document.createElement('div');
            item.className = `sidebar-item ${v.id === selectedVaultId ? 'active' : ''}`;
            item.innerHTML = `${ICON_FOLDER} <span>${v.name}</span>`;
            item.onclick = () => selectVault(v.id, v.name);
            list.appendChild(item);
        });
    };
}

function createVault() {
    const name = document.getElementById('newVaultName').value.trim() || 'New Vault';
    const pw = document.getElementById('newVaultPassword').value;
    if (!pw) return;
    const salt = generateSalt();
    hashPassword(pw, salt).then(hash => {
        const tx = db.transaction(["vaults"], "readwrite");
        const vaultRecord = { name, salt, passwordHash: hash };
        const req = tx.objectStore("vaults").add(vaultRecord);
        
        tx.oncomplete = async () => {
            selectedVaultId = req.result;
            currentVault = { id: selectedVaultId, ...vaultRecord };
            activeCryptoKey = await deriveKey(pw, salt); 
            
            closeModal('createVaultModal');
            loadVaults();
            
            document.getElementById('viewUnlock').classList.add('hidden');
            document.getElementById('viewEmpty').classList.add('hidden');
            document.getElementById('systemFolders').classList.remove('hidden');
            document.getElementById('actionRibbon').classList.remove('v-hidden');
            switchSystemView('files');
        };
    });
}

function selectVault(id, name) {
    if (selectedVaultId === id && activeCryptoKey) return;
    lockVault();
    selectedVaultId = id;
    document.getElementById('unlockTitle').textContent = `Unlock '${name}'`;
    document.getElementById('viewEmpty').classList.add('hidden');
    document.getElementById('viewUnlock').classList.remove('hidden');
    document.getElementById('vaultPasswordInput').focus();
    loadVaults();
}

async function unlockVault() {
    const pw = document.getElementById('vaultPasswordInput').value;
    if(!pw || !selectedVaultId) return;
    db.transaction(["vaults"],"readonly").objectStore("vaults").get(selectedVaultId).onsuccess = async (e) => {
        currentVault = e.target.result;
        if(await hashPassword(pw, currentVault.salt) !== currentVault.passwordHash) return alert("Wrong password.");
        activeCryptoKey = await deriveKey(pw, currentVault.salt);
        
        document.getElementById('vaultPasswordInput').value = ''; 
        document.getElementById('viewUnlock').classList.add('hidden'); 
        document.getElementById('systemFolders').classList.remove('hidden');
        document.getElementById('actionRibbon').classList.remove('v-hidden');
        switchSystemView('files');
        loadVaults();
    };
}

function lockVault() {
    currentVault = null; activeCryptoKey = null; editingFileId = null; currentDirectoryPath = "/";
    draggedItemId = null; renamingItemId = null;
    
    document.querySelectorAll("input[type='password']").forEach(input => input.value = '');
    document.getElementById('searchInput').value = '';

    document.getElementById('systemFolders').classList.add('hidden');
    document.getElementById('actionRibbon').classList.add('v-hidden');
    document.getElementById('viewUnlock').classList.add('hidden');
    document.getElementById('viewFiles').classList.add('hidden');
    document.getElementById('viewEditor').classList.add('hidden');
    document.getElementById('emptyFilesMsg').classList.add('hidden'); 
    document.getElementById('viewEmpty').classList.remove('hidden');
    document.getElementById('breadcrumb').textContent = "This PC > Select a Vault";
}

function openVaultSettingsModal() {
    if (!currentVault) return;
    document.getElementById('settingsVaultName').value = currentVault.name;
    document.getElementById('settingsVaultPassword').value = '';
    openModal('vaultSettingsModal');
}

async function saveVaultSettings() {
    const newName = document.getElementById('settingsVaultName').value.trim();
    const newPassword = document.getElementById('settingsVaultPassword').value;
    if (!newName) return;

    const tx = db.transaction(["vaults"], "readwrite");
    const store = tx.objectStore("vaults");

    store.get(currentVault.id).onsuccess = async (e) => {
        const vault = e.target.result;
        vault.name = newName;

        if (newPassword) {
            const newSalt = generateSalt();
            vault.salt = newSalt;
            vault.passwordHash = await hashPassword(newPassword, newSalt);
            activeCryptoKey = await deriveKey(newPassword, newSalt);
        }

        store.put(vault);
        currentVault = vault;
    };

    tx.oncomplete = () => {
        closeModal('vaultSettingsModal');
        loadVaults();
        renderBreadcrumbs();
    };
}

function deleteVault() {
    if(!selectedVaultId || !activeCryptoKey || !confirm("Delete vault and ALL data inside forever?")) return;
    const tx = db.transaction(["vaults", "files"], "readwrite");
    tx.objectStore("vaults").delete(selectedVaultId);
    const fileStore = tx.objectStore("files");
    fileStore.index("vaultId").getAllKeys(selectedVaultId).onsuccess = (e) => e.target.result.forEach(id => fileStore.delete(id));
    tx.oncomplete = () => { selectedVaultId = null; lockVault(); loadVaults(); };
}

// --- File Modifying & Renaming Systems ---
function openRenameItemModal(id, currentName) {
    renamingItemId = id;
    document.getElementById('renameItemInput').value = currentName;
    openModal('renameItemModal');
}

function saveItemRename() {
    const newName = document.getElementById('renameItemInput').value.trim();
    if (!newName || !renamingItemId) return;

    const tx = db.transaction(["files"], "readwrite");
    const store = tx.objectStore("files");

    store.get(renamingItemId).onsuccess = (e) => {
        const item = e.target.result;
        item.name = newName;
        store.put(item);
    };

    tx.oncomplete = () => {
        closeModal('renameItemModal');
        renamingItemId = null;
        loadFiles();
    };
}

async function createFolder() {
    const name = document.getElementById('newFolderName').value.trim();
    if(!name || !activeCryptoKey) return;
    await saveEncryptedData(name, "folder", new TextEncoder().encode("").buffer);
    closeModal('createFolderModal');
    loadFiles();
}

function saveEncryptedData(name, type, buffer, fileId = null) {
    const iv = crypto.getRandomValues(new Uint8Array(12));
    return crypto.subtle.encrypt({ name: 'AES-GCM', iv }, activeCryptoKey, buffer).then(enc => {
        return new Promise(res => {
            const tx = db.transaction(["files"], "readwrite");
            const store = tx.objectStore("files");
            
            if(fileId) {
                store.get(fileId).onsuccess = (e) => {
                    const existing = e.target.result;
                    existing.name = name;
                    existing.iv = Array.from(iv);
                    existing.data = enc;
                    store.put(existing);
                };
            } else {
                const payload = { 
                    vaultId: currentVault.id, name, type, 
                    iv: Array.from(iv), data: enc, 
                    path: currentDirectoryPath, favorite: false, isTrash: false 
                };
                store.put(payload);
            }
            tx.oncomplete = () => { updateStorageSpace(); res(); };
        });
    });
}

function loadFiles() {
    if (!activeCryptoKey) return;
    db.transaction(["files"],"readonly").objectStore("files").index("vaultId").getAll(currentVault.id).onsuccess = (e) => {
        runtimeCachedItems = e.target.result;
        filterItems();
    };
}

function filterItems() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    let filtered = runtimeCachedItems;

    if(currentSystemView === 'files') {
        filtered = filtered.filter(i => !i.isTrash && (i.path || "/") === currentDirectoryPath);
    } else if(currentSystemView === 'favorites') {
        filtered = filtered.filter(i => !i.isTrash && i.favorite);
    } else if(currentSystemView === 'trash') {
        filtered = filtered.filter(i => i.isTrash);
    }

    if(query) {
        filtered = filtered.filter(i => i.name.toLowerCase().includes(query));
    }

    filtered.sort((a,b) => {
        if(a.type === 'folder' && b.type !== 'folder') return -1;
        if(a.type !== 'folder' && b.type === 'folder') return 1;
        let comp = a[sortField].localeCompare(b[sortField]);
        return sortAsc ? comp : -comp;
    });

    renderWorkspaceLayout(filtered);
}

function renderWorkspaceLayout(items) {
    if (!activeCryptoKey) return;
    document.getElementById('viewFiles').classList.remove('hidden');
    document.getElementById('viewEditor').classList.add('hidden');
    
    const tableEl = document.getElementById('fileTable');
    const gridEl = document.getElementById('gridViewContainer');
    const emptyMsg = document.getElementById('emptyFilesMsg');

    if(items.length === 0) {
        emptyMsg.classList.remove('hidden'); 
        tableEl.classList.add('hidden'); 
        gridEl.classList.add('hidden');
        return;
    }
    emptyMsg.classList.add('hidden');

    if(viewMode === 'list') {
        tableEl.classList.remove('hidden'); gridEl.classList.add('hidden');
        renderListView(items);
    } else {
        tableEl.classList.add('hidden'); gridEl.classList.remove('hidden');
        renderGridView(items);
    }
}

function toggleSort(field) {
    if(sortField === field) sortAsc = !sortAsc; else { sortField = field; sortAsc = true; }
    document.getElementById('sortDirection').textContent = sortAsc ? " ↑" : " ↓";
    filterItems();
}

function renderListView(items) {
    const tbody = document.getElementById('fileListBody');
    tbody.innerHTML = '';
    items.forEach(f => {
        const isFolder = f.type === "folder";
        const isText = !isFolder && (f.name.endsWith('.txt') || f.name.endsWith('.md') || f.type.startsWith('text/'));
        const icon = isFolder ? ICON_FOLDER : (isText ? ICON_FILE_TEXT : ICON_FILE_GENERIC);
        const favClass = f.favorite ? 'star-filled' : '';

        let cellClickAttribute = "";
        let nameContentsHtml = "";

        if (isFolder) {
            cellClickAttribute = `class="clickable-cell" onclick="navigateToPath('${(currentDirectoryPath+f.name+'/').replace(/'/g, "\\'")}')"`;
            nameContentsHtml = `<div class="col-name">${icon} <span>${f.name}</span></div>`;
        } else {
            cellClickAttribute = `class="col-name"`;
            nameContentsHtml = `${icon} ${isText ? `<a href="#" style="color:var(--text-main); text-decoration:none; font-weight:500;" onclick="openTextEditor(${f.id}, '${f.name.replace(/'/g, "\\'")}')">${f.name}</a>` : `<span>${f.name}</span>`}`;
        }

        const actionButtons = f.isTrash 
            ? `<button class="btn-icon" title="Restore" onclick="restoreFromTrash(${f.id})"><svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg></button>
               <button class="btn-icon" title="Delete Permanently" style="color:var(--danger)" onclick="permanentDelete(${f.id})"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>`
            : `<button class="btn-icon" title="Rename" onclick="openRenameItemModal(${f.id}, '${f.name.replace(/'/g, "\\'")}')"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"></path></svg></button>
               <button class="btn-icon ${favClass}" onclick="toggleFavorite(${f.id})"><svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg></button>
               ${!isFolder ? `<button class="btn-icon" onclick="downloadFile(${f.id})"><svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg></button>` : ''}
               <button class="btn-icon" style="color:var(--danger)" onclick="moveToTrash(${f.id})"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></button>`;

        const tr = document.createElement('tr');
        tr.className = "draggable-row";
        tr.draggable = true;
        
        tr.ondragstart = (e) => handleItemDragStart(e, f.id);
        tr.ondragover = (e) => handleItemDragOver(e, tr, f.type);
        tr.ondragleave = () => handleItemDragLeave(tr);
        tr.ondrop = (e) => handleItemDrop(e, tr, f.name);

        tr.innerHTML = `<td ${cellClickAttribute}>${nameContentsHtml}</td><td style="color:var(--text-muted);">${isFolder?'Folder':f.type}</td><td class="col-actions">${actionButtons}</td>`;
        tbody.appendChild(tr);
    });
}

function renderGridView(items) {
    const container = document.getElementById('gridViewContainer');
    container.innerHTML = '';
    items.forEach(f => {
        const isFolder = f.type === "folder";
        const isText = !isFolder && (f.name.endsWith('.txt') || f.name.endsWith('.md') || f.type.startsWith('text/'));
        const icon = isFolder ? ICON_FOLDER : (isText ? ICON_FILE_TEXT : ICON_FILE_GENERIC);
        
        const card = document.createElement('div');
        card.className = 'grid-card';
        card.draggable = true;

        card.ondragstart = (e) => handleItemDragStart(e, f.id);
        card.ondragover = (e) => handleItemDragOver(e, card, f.type);
        card.ondragleave = () => handleItemDragLeave(card);
        card.ondrop = (e) => handleItemDrop(e, card, f.name);
        
        card.onclick = (e) => {
            if(e.target.closest('button') || e.target.closest('.fav-star')) return;
            if(isFolder) navigateToPath(currentDirectoryPath + f.name + "/");
            else if(isText) openTextEditor(f.id, f.name);
        };

        const actionButtons = f.isTrash 
            ? `<button class="btn-icon" onclick="restoreFromTrash(${f.id})"><svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"></polyline></svg></button>
               <button class="btn-icon" style="color:var(--danger)" onclick="permanentDelete(${f.id})"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line></svg></button>`
            : `<button class="btn-icon" title="Rename" onclick="openRenameItemModal(${f.id}, '${f.name.replace(/'/g, "\\'")}')"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"></path></svg></button>
               ${!isFolder ? `<button class="btn-icon" onclick="downloadFile(${f.id})"><svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path></svg></button>` : ''}
               <button class="btn-icon" style="color:var(--danger)" onclick="moveToTrash(${f.id})"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline></svg></button>`;

        card.innerHTML = `
            ${!f.isTrash ? `<div class="fav-star ${f.favorite?'star-filled':''}" onclick="toggleFavorite(${f.id})"><svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg></div>` : ''}
            <div class="main-icon">${icon}</div>
            <div class="card-name" title="${f.name}">${f.name}</div>
            <div class="card-actions">${actionButtons}</div>
        `;
        container.appendChild(card);
    });
}

function toggleFavorite(id) {
    const tx = db.transaction(["files"],"readwrite");
    const store = tx.objectStore("files");
    store.get(id).onsuccess = (e) => {
        const item = e.target.result;
        item.favorite = !item.favorite;
        store.put(item);
    };
    tx.oncomplete = () => loadFiles();
}

function moveToTrash(id) {
    if(!confirm("Move this item to the Recycle Bin?")) return;
    const tx = db.transaction(["files"],"readwrite");
    const store = tx.objectStore("files");
    store.get(id).onsuccess = (e) => {
        const item = e.target.result;
        item.isTrash = true;
        store.put(item);
    };
    tx.oncomplete = () => loadFiles();
}

function restoreFromTrash(id) {
    const tx = db.transaction(["files"],"readwrite");
    const store = tx.objectStore("files");
    store.get(id).onsuccess = (e) => {
        const item = e.target.result;
        item.isTrash = false;
        store.put(item);
    };
    tx.oncomplete = () => loadFiles();
}

function permanentDelete(id) {
    if(!confirm("Permanently destroy this item?")) return;
    const tx = db.transaction(["files"],"readwrite");
    tx.objectStore("files").delete(id);
    tx.oncomplete = () => loadFiles();
}

function downloadFile(id) {
    db.transaction(["files"],"readonly").objectStore("files").get(id).onsuccess = (e) => {
        const rec = e.target.result;
        crypto.subtle.decrypt({name:'AES-GCM', iv: new Uint8Array(rec.iv)}, activeCryptoKey, rec.data).then(dec => {
            const a = document.createElement('a');
            a.href = URL.createObjectURL(new Blob([dec], {type: rec.type}));
            a.download = rec.name;
            a.click();
        });
    };
}

function initiateNewTextFile() {
    let name = document.getElementById('newFileName').value.trim() || "notes.txt";
    if(!name.includes('.')) name += ".txt";
    editingFileId = null;
    document.getElementById('editorFilename').textContent = name;
    document.getElementById('editorTextarea').value = "";
    closeModal('createTextFileModal');
    document.getElementById('viewFiles').classList.add('hidden');
    document.getElementById('viewEditor').classList.remove('hidden');
    document.getElementById('editorTextarea').focus();
}

function openTextEditor(id, name) {
    db.transaction(["files"],"readonly").objectStore("files").get(id).onsuccess = (e) => {
        const item = e.target.result;
        crypto.subtle.decrypt({name:'AES-GCM', iv: new Uint8Array(item.iv)}, activeCryptoKey, item.data).then(dec => {
            editingFileId = id;
            document.getElementById('editorFilename').textContent = name;
            document.getElementById('editorTextarea').value = new TextDecoder().decode(dec);
            document.getElementById('viewFiles').classList.add('hidden');
            document.getElementById('viewEditor').classList.remove('hidden');
        });
    };
}

function closeEditor() { loadFiles(); }
async function saveEditorFile() {
    const text = document.getElementById('editorTextarea').value;
    const name = document.getElementById('editorFilename').textContent;
    await saveEncryptedData(name, 'text/plain', new TextEncoder().encode(text).buffer, editingFileId);
    loadFiles();
}

async function updateStorageSpace() {
    if (navigator.storage && navigator.storage.estimate) {
        const est = await navigator.storage.estimate();
        const u = est.usage || 0, q = est.quota || 1;
        document.getElementById('storageText').textContent = `${(u/(1024*1024)).toFixed(1)} MB of ${(q/(1024*1024*1024)).toFixed(1)} GB used`;
        document.getElementById('storageBar').style.width = `${((u/q)*100).toFixed(1)}%`;
    }
}
</script>
