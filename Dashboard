<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Impact Analytics Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        html, body {
            width: 100% !important;
            height: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
        }
        /* Custom scrollbar track for the log table view */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(15, 23, 42, 0.5);
        }
        ::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 3px;
        }
    </style>
</head>
<body class="bg-slate-900 text-slate-100 font-sans antialiased flex flex-col justify-between min-h-screen">

    <div class="w-full h-full p-4 md:p-6 flex flex-col gap-6 flex-grow">
        
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center border-b border-slate-800 pb-4 gap-4">
            <div>
                <h1 class="text-2xl font-bold tracking-tight text-white">IMU Impact Analytics</h1>
                <p class="text-sm text-slate-400">Real-time device telemetry and event categorization</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4 w-full md:w-auto justify-between md:justify-end">
                <div class="bg-slate-950 p-1 rounded-xl border border-slate-800 flex gap-1">
                    <button id="btn-chart" onclick="switchMode('chart')" class="px-4 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all duration-200 bg-slate-800 text-white shadow-md">
                        Chart View
                    </button>
                    <button id="btn-log" onclick="switchMode('log')" class="px-4 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all duration-200 text-slate-400 hover:text-white">
                        Log View
                    </button>
                </div>

                <div class="flex gap-3 text-xs bg-slate-800/30 px-3 py-2 rounded-xl border border-slate-800/60">
                    <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-sm shadow-emerald-500/50"></span> Roll</span>
                    <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-amber-500 shadow-sm shadow-amber-500/50"></span> Toss</span>
                    <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-rose-500 shadow-sm shadow-rose-500/50"></span> Drop</span>
                </div>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 flex-grow h-full items-stretch">
            
            <div class="lg:col-span-2 bg-slate-800/40 border border-slate-800 p-5 rounded-2xl shadow-xl backdrop-blur-sm flex flex-col min-h-[400px]">
                
                <div id="view-chart-container" class="relative w-full flex-grow h-full min-h-0">
                    <canvas id="impactChart"></canvas>
                </div>

                <div id="view-log-container" class="hidden w-full flex-grow h-full overflow-y-auto min-h-0">
                    <div class="inline-block min-w-full align-middle">
                        <table class="min-w-full divide-y divide-slate-800/80 text-left">
                            <thead>
                                <tr class="text-slate-400 text-xs font-bold uppercase tracking-wider">
                                    <th scope="col" class="py-3 px-4">Event #</th>
                                    <th scope="col" class="py-3 px-4">Timestamp</th>
                                    <th scope="col" class="py-3 px-4">Impact Profile</th>
                                    <th scope="col" class="py-3 px-4 text-right">Intensity Scale</th>
                                </tr>
                            </thead>
                            <tbody id="log-table-body" class="divide-y divide-slate-800/40 text-sm font-medium">
                                </tbody>
                        </table>
                    </div>
                </div>

            </div>

            <div class="bg-slate-800 border border-slate-800/80 p-6 rounded-2xl shadow-xl flex flex-col justify-between h-full min-h-[300px]">
                <div>
                    <h2 class="text-lg font-semibold text-white mb-2">Event Inspector</h2>
                    <p class="text-xs text-slate-400 mb-6">Select or click directly on an entry pattern row to decode its micro-sensor parameters.</p>
                    
                    <div id="inspector-default" class="text-center py-12 text-slate-500 text-sm italic border-2 border-dashed border-slate-700/60 rounded-xl bg-slate-900/20">
                        No metric selected
                    </div>
                    
                    <div id="inspector-data" class="hidden space-y-4">
                        <div class="bg-slate-900/50 p-4 rounded-xl border border-slate-700/30">
                            <span class="block text-xs uppercase tracking-wider text-slate-400 font-medium mb-1">Impact Event Type</span>
                            <span id="info-type" class="text-lg font-black tracking-wide">--</span>
                        </div>
                        
                        <div class="bg-slate-900/50 p-4 rounded-xl border border-slate-700/30">
                            <span class="block text-xs uppercase tracking-wider text-slate-400 font-medium mb-1">Timestamp</span>
                            <span id="info-time" class="text-sm font-mono text-emerald-400 font-semibold">--</span>
                        </div>
                        
                        <div class="bg-slate-900/50 p-4 rounded-xl border border-slate-700/30">
                            <span class="block text-xs uppercase tracking-wider text-slate-400 font-medium mb-1">Peak Intensity</span>
                            <span id="info-intensity" class="text-3xl font-extrabold text-white tracking-tight">
                                -- <span class="text-xs font-normal text-slate-400 ml-1">Gs</span>
                            </span>
                        </div>
                    </div>
                </div>
                
                <div class="text-[11px] text-slate-500 border-t border-slate-700/40 pt-4 mt-6 flex justify-between items-center">
                    <span>Linear scaling map applied: ($r \propto G$)</span>
                    <span class="font-mono text-slate-600">v1.1.0</span>
                </div>
            </div>

        </div>
    </div>

    <script>
        // fake data for testing
        const final_impact_log = [
            ["14:22:05", 2.93, "roll"], 
            ["14:22:12", 3.16, "toss"], 
            ["14:22:31", 8.36, "drop"]
        ];

        const colors = {
            roll: { fill: 'rgba(16, 185, 129, 0.55)', border: 'rgb(16, 185, 129)', text: 'text-emerald-400', bg: 'bg-emerald-500/10 border-emerald-500/20' }, 
            toss: { fill: 'rgba(245, 158, 11, 0.55)', border: 'rgb(245, 158, 11)', text: 'text-amber-400', bg: 'bg-amber-500/10 border-amber-500/20' },  
            drop: { fill: 'rgba(244, 63, 94, 0.55)', border: 'rgb(244, 63, 94)', text: 'text-rose-400', bg: 'bg-rose-500/10 border-rose-500/20' }     
        };

        // Format raw debugging data into Chart.js coordinate map layout
        const chartDataPoints = final_impact_log.map(item => ({
            x: item[0], // Time
            y: item[1], // Intensity 
            r: (item[1] * 3.5) + 6, // Radius scale
            type: item[2] // Type
        }));

        // -------- TOGGLE UI MODES ---------
        function switchMode(mode) {
            const chartBtn = document.getElementById('btn-chart');
            const logBtn = document.getElementById('btn-log');
            const chartView = document.getElementById('view-chart-container');
            const logView = document.getElementById('view-log-container');

            if (mode === 'chart') {
                chartBtn.className = "px-4 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all duration-200 bg-slate-800 text-white shadow-md";
                logBtn.className = "px-4 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all duration-200 text-slate-400 hover:text-white";
                chartView.classList.remove('hidden');
                logView.classList.add('hidden');
            } else {
                logBtn.className = "px-4 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all duration-200 bg-slate-800 text-white shadow-md";
                chartBtn.className = "px-4 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all duration-200 text-slate-400 hover:text-white";
                chartView.classList.add('hidden');
                logView.classList.remove('hidden');
            }
        }

        // -------- CONSOLE LOG TABLE --------
        const tableBody = document.getElementById('log-table-body');
        final_impact_log.forEach((event, index) => {
            const time = event[0];
            const intensity = event[1];
            const type = event[2];
            const profile = colors[type];

            const row = document.createElement('tr');
            row.className = "hover:bg-slate-800/30 cursor-pointer border-b border-slate-800/40 transition-colors";
            
            // Map table clicks directly to the close inspection panel
            row.onclick = () => updateInspectorUI({ x: time, y: intensity, type: type });

            row.innerHTML = `
                <td class="py-3 px-4 text-slate-500 font-mono text-xs">#0${index + 1}</td>
                <td class="py-3 px-4 font-mono text-slate-300">${time}</td>
                <td class="py-3 px-4">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-bold border ${profile.bg} ${profile.text}">
                        ${type.toUpperCase()}
                    </span>
                </td>
                <td class="py-3 px-4 text-right font-bold text-white">${intensity.toFixed(2)} <span class="text-xs font-normal text-slate-500">Gs</span></td>
            `;
            tableBody.appendChild(row);
        });

        // -------- CHART ENGINE CONFIGURATION --------
        const ctx = document.getElementById('impactChart').getContext('2d');
        const impactChart = new Chart(ctx, {
            type: 'bubble',
            data: {
                datasets: [{
                    data: chartDataPoints,
                    backgroundColor: chartDataPoints.map(p => colors[p.type].fill),
                    borderColor: chartDataPoints.map(p => colors[p.type].border),
                    borderWidth: 2,
                    hoverBorderWidth: 3,
                    hoverRadius: 2,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }, 
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.95)',
                        borderColor: 'rgba(51, 65, 85, 0.5)',
                        borderWidth: 1,
                        padding: 10,
                        callbacks: {
                            label: (context) => ` [${context.raw.type.toUpperCase()}] Intensity: ${context.raw.y} Gs`
                        }
                    }
                },
                scales: {
                    x: {
                        type: 'category', 
                        grid: { color: 'rgba(51, 65, 85, 0.15)', drawTicks: false },
                        title: { display: true, text: 'System Timeline Log', color: '#64748b', font: { weight: 'bold' } },
                        ticks: { color: '#94a3b8', padding: 8 }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(51, 65, 85, 0.15)', drawTicks: false },
                        title: { display: true, text: 'Intensity Magnitude (G-Force Accel)', color: '#64748b', font: { weight: 'bold' } },
                        ticks: { color: '#94a3b8', padding: 8 }
                    }
                },
                onClick: (event, elements) => {
                    if (elements.length > 0) {
                        const index = elements[0].index;
                        updateInspectorUI(impactChart.data.datasets[0].data[index]);
                    }
                }
            }
        });

        // -------- SIDEBAR CLOSE INSPECTION PANEL --------
        function updateInspectorUI(node) {
            document.getElementById('inspector-default').classList.add('hidden');
            document.getElementById('inspector-data').classList.remove('hidden');

            const typeLabel = document.getElementById('info-type');
            typeLabel.innerText = node.type.toUpperCase();
            
            typeLabel.className = "text-lg font-black tracking-wide";
            if(node.type === 'roll') typeLabel.classList.add('text-emerald-400');
            if(node.type === 'toss') typeLabel.classList.add('text-amber-400');
            if(node.type === 'drop') typeLabel.classList.add('text-rose-400');

            document.getElementById('info-time').innerText = node.x;
            document.getElementById('info-intensity').innerHTML = `${node.y} <span class="text-sm font-normal text-slate-400 ml-1">Gs</span>`;
        }
    </script>
</body>
</html>
